model Tenant {
  tenantId String @id() @default(uuid()) @map("tanant_id") @db.Uuid

  name    String @unique
  ownerId String @unique @map("owner_id") @db.Uuid

  suspendedAt DateTime? @map("suspended_at") @db.Timestamptz(6)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // relations
  owner                  User                    @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  subscription           TenantSubscription?
  enterprisePlans        Plan[]                  @relation("EnterprisePlanTenant")
  usage                  TenantUsage?
  enterprisePlanRequests EnterprisePlanRequest[]

  @@map("tenants")
}
